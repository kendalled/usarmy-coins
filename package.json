{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "case \"$npm_config_user_agent\" in *bun*) exit 0;; *) echo 'This project is bun-only. Use: bun install' >&2; exit 1;; esac",
    "build": "bunx --bun nuxi build",
    "dev": "bunx --bun nuxi dev",
    "generate": "bunx --bun nuxi generate",
    "preview": "bunx --bun nuxi preview",
    "postinstall": "bunx --bun nuxi prepare"
  },
  "dependencies": {
    "@nuxt/content": "^3.6.3",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.11",
    "nuxt": "^4.0.1",
    "vue": "^3.5.17",
    "vue-router": "^4.5.1"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@tailwindcss/oxide"
  ],
  "engines": {
    "node": ">=20 <24"
  },
  "packageManager": "bun@1.3.6"
}
